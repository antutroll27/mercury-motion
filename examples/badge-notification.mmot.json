{
  "version": "1.0",
  "meta": {
    "name": "BadgeNotification",
    "width": 400,
    "height": 400,
    "fps": 30,
    "duration": 30,
    "background": "#1a1a2e",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "bg",
          "type": "solid",
          "in": 0,
          "out": 30,
          "color": "#1a1a2e",
          "fill": "parent",
          "transform": { "position": [200, 200] }
        },
        {
          "id": "badge_shadow",
          "type": "shape",
          "in": 0,
          "out": 30,
          "shape": { "shape_type": "ellipse", "width": 90, "height": 90, "fill": "#cc0000" },
          "transform": {
            "position": [200, 204],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 260.0, "damping": 12.0, "mass": 1.0 } },
              { "t": 20, "v": [1.0, 1.0] }
            ],
            "opacity": 0.3
          },
          "effects": [
            { "type": "gaussian_blur", "radius": 8.0 }
          ]
        },
        {
          "id": "badge_circle",
          "type": "shape",
          "in": 0,
          "out": 30,
          "shape": { "shape_type": "ellipse", "width": 90, "height": 90, "fill": "#e53935" },
          "transform": {
            "position": [200, 200],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 260.0, "damping": 12.0, "mass": 1.0 } },
              { "t": 20, "v": [1.0, 1.0] }
            ]
          },
          "effects": [
            { "type": "glow", "color": "#e53935", "radius": 15.0, "intensity": 0.3 }
          ]
        },
        {
          "id": "badge_highlight",
          "type": "shape",
          "in": 0,
          "out": 30,
          "shape": { "shape_type": "ellipse", "width": 80, "height": 80, "fill": "#ff5252" },
          "transform": {
            "position": [200, 198],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 260.0, "damping": 12.0, "mass": 1.0 } },
              { "t": 20, "v": [0.6, 0.6] }
            ],
            "opacity": 0.3
          },
          "effects": [
            { "type": "gaussian_blur", "radius": 12.0 }
          ]
        },
        {
          "id": "badge_number",
          "type": "text",
          "in": 5,
          "out": 30,
          "text": "3",
          "font": { "family": "Arial", "size": 48.0, "weight": 700, "color": "#ffffff" },
          "transform": {
            "position": [200, 200],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 300.0, "damping": 14.0, "mass": 1.0 } },
              { "t": 15, "v": [1.0, 1.0] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 5, "v": 1.0 }
            ]
          }
        },
        {
          "id": "glow_pulse",
          "type": "shape",
          "in": 15,
          "out": 30,
          "shape": { "shape_type": "ellipse", "width": 100, "height": 100, "fill": "#e53935" },
          "transform": {
            "position": [200, 200],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "ease_out" },
              { "t": 10, "v": [1.5, 1.5] }
            ],
            "opacity": [
              { "t": 0, "v": 0.4, "easing": "ease_out" },
              { "t": 10, "v": 0.0 }
            ]
          },
          "effects": [
            { "type": "gaussian_blur", "radius": 15.0 }
          ]
        }
      ]
    }
  }
}
