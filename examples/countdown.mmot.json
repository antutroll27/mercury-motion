            "position": [540, 540],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 220.0, "damping": 10.0, "mass": 1.0 } },
              { "t": 18, "v": [1.0, 1.0] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 4, "v": 1.0 }
            ]
          },
          "effects": [
            { "type": "glow", "color": "#00ff88", "radius": 30.0, "intensity": 0.7 }
          ]
        }
