              { "t": 0, "v": [0.6, 0.6], "easing": { "type": "spring", "stiffness": 200.0, "damping": 12.0, "mass": 1.0 } },
              { "t": 15, "v": [1.0, 1.0] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 5, "v": 0.4 },
              { "t": 15, "v": 0.4, "easing": "ease_in" },
              { "t": 22, "v": 0.0 }
            ]
          }
        },
        {
          "id": "text_1",
          "type": "text",
          "in": 0,
          "out": 22,
          "text": "1",
          "font": { "family": "Arial", "size": 180.0, "weight": 900, "color": "#ff4444" },
          "transform": {
