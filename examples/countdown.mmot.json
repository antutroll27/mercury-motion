              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 4, "v": 1.0 },
              { "t": 15, "v": 1.0, "easing": "ease_in" },
              { "t": 22, "v": 0.0 }
            ]
          }
        }
