{
  "version": "1.0",
  "meta": {
    "name": "Slideshow",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 180,
    "background": "#0a0a0f",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "slides",
          "type": "composition",
          "in": 0,
          "out": 180,
          "composition_id": "slide_sequence",
          "transform": { "position": [960, 540] }
        }
      ]
    },
    "slide_sequence": {
      "sequence": true,
      "transition": { "type": "crossfade", "duration": 15 },
      "layers": [
        {
          "id": "slide_1",
          "type": "composition",
          "in": 0,
          "out": 60,
          "composition_id": "slide_ocean",
          "transform": { "position": [960, 540] }
        },
        {
          "id": "slide_2",
          "type": "composition",
          "in": 0,
          "out": 60,
          "composition_id": "slide_sunset",
          "transform": { "position": [960, 540] }
        },
        {
          "id": "slide_3",
          "type": "composition",
          "in": 0,
          "out": 60,
          "composition_id": "slide_forest",
          "transform": { "position": [960, 540] }
        }
      ]
    },
    "slide_ocean": {
      "layers": [
        {
          "id": "ocean_bg",
          "type": "gradient",
          "in": 0,
          "out": 60,
          "gradient": {
            "gradient_type": "linear",
            "start": [0.0, 0.0],
            "end": [0.0, 1.0],
            "colors": [
              { "offset": 0.0, "color": "#003049" },
              { "offset": 0.5, "color": "#005f73" },
              { "offset": 1.0, "color": "#0a9396" }
            ]
          },
          "fill": "parent",
          "transform": {
            "position": [960, 540],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "linear" },
              { "t": 60, "v": [1.15, 1.15] }
            ]
          }
        },
        {
          "id": "ocean_caption",
          "type": "text",
          "in": 10,
          "out": 50,
          "text": "Ocean Breeze",
          "font": { "family": "Arial", "size": 56.0, "weight": 300, "color": "#fdf0d5" },
          "transform": {
            "position": [960, 900],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 1.0 },
              { "t": 30, "v": 1.0, "easing": "ease_in" },
              { "t": 40, "v": 0.0 }
            ]
          },
          "effects": [
            { "type": "drop_shadow", "color": "#000000", "offset_x": 0.0, "offset_y": 2.0, "blur": 8.0, "opacity": 0.6 }
          ]
        }
      ]
    },
    "slide_sunset": {
      "layers": [
        {
          "id": "sunset_bg",
          "type": "gradient",
          "in": 0,
          "out": 60,
          "gradient": {
            "gradient_type": "linear",
            "start": [0.0, 0.0],
            "end": [0.0, 1.0],
            "colors": [
              { "offset": 0.0, "color": "#1a0a2e" },
              { "offset": 0.4, "color": "#6b2fa0" },
              { "offset": 0.7, "color": "#ff6b6b" },
              { "offset": 1.0, "color": "#ffd93d" }
            ]
          },
          "fill": "parent",
          "transform": {
            "position": [960, 540],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "linear" },
              { "t": 60, "v": [1.12, 1.12] }
            ]
          }
        },
        {
          "id": "sunset_caption",
          "type": "text",
          "in": 10,
          "out": 50,
          "text": "Golden Hour",
          "font": { "family": "Arial", "size": 56.0, "weight": 300, "color": "#ffffff" },
          "transform": {
            "position": [960, 900],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 1.0 },
              { "t": 30, "v": 1.0, "easing": "ease_in" },
              { "t": 40, "v": 0.0 }
            ]
          },
          "effects": [
            { "type": "drop_shadow", "color": "#000000", "offset_x": 0.0, "offset_y": 2.0, "blur": 8.0, "opacity": 0.6 }
          ]
        }
      ]
    },
    "slide_forest": {
      "layers": [
        {
          "id": "forest_bg",
          "type": "gradient",
          "in": 0,
          "out": 60,
          "gradient": {
            "gradient_type": "linear",
            "start": [0.0, 0.0],
            "end": [0.5, 1.0],
            "colors": [
              { "offset": 0.0, "color": "#0b3d2e" },
              { "offset": 0.5, "color": "#145a32" },
              { "offset": 1.0, "color": "#1e8449" }
            ]
          },
          "fill": "parent",
          "transform": {
            "position": [960, 540],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "linear" },
              { "t": 60, "v": [1.1, 1.1] }
            ]
          }
        },
        {
          "id": "forest_caption",
          "type": "text",
          "in": 10,
          "out": 50,
          "text": "Into the Wild",
          "font": { "family": "Arial", "size": 56.0, "weight": 300, "color": "#e8f5e9" },
          "transform": {
            "position": [960, 900],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 1.0 },
              { "t": 30, "v": 1.0, "easing": "ease_in" },
              { "t": 40, "v": 0.0 }
            ]
          },
          "effects": [
            { "type": "drop_shadow", "color": "#000000", "offset_x": 0.0, "offset_y": 2.0, "blur": 8.0, "opacity": 0.6 }
          ]
        }
      ]
    }
  }
}
