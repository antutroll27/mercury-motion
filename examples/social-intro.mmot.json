{
  "version": "1.0",
  "meta": {
    "name": "SocialIntro",
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "duration": 90,
    "background": "#0a0a0f",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "bg_gradient",
          "type": "gradient",
          "in": 0,
          "out": 90,
          "gradient": {
            "gradient_type": "radial",
            "center": [0.5, 0.4],
            "radius": 0.9,
            "colors": [
              { "offset": 0.0, "color": "#1a1028" },
              { "offset": 0.6, "color": "#0f0a18" },
              { "offset": 1.0, "color": "#0a0a0f" }
            ]
          },
          "fill": "parent",
          "transform": { "position": [540, 540] }
        },
        {
          "id": "separator_line",
          "type": "shape",
          "in": 20,
          "out": 90,
          "shape": {
            "shape_type": "rect",
            "width": 300,
            "height": 2,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [540, 520],
            "scale": [
              { "t": 0, "v": [0.0, 1.0], "easing": { "type": "cubic_bezier", "x1": 0.16, "y1": 1.0, "x2": 0.3, "y2": 1.0 } },
              { "t": 20, "v": [1.0, 1.0] }
            ],
            "opacity": 1.0
          }
        },
        {
          "id": "brand_name",
          "type": "text",
          "in": 5,
          "out": 90,
          "text": "MERCURY",
          "font": {
            "family": "Arial",
            "size": 96.0,
            "weight": 700,
            "color": "#f5f0e8"
          },
          "transform": {
            "position": [
              { "t": 0, "v": [540, 520], "easing": { "type": "spring", "stiffness": 180.0, "damping": 14.0, "mass": 1.0 } },
              { "t": 30, "v": [540, 470] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 12, "v": 1.0 }
            ]
          },
          "effects": [
            { "type": "glow", "color": "#c1121f", "radius": 20.0, "intensity": 0.4 }
          ]
        },
        {
          "id": "tagline",
          "type": "text",
          "in": 30,
          "out": 90,
          "text": "Motion Design Studio",
          "font": {
            "family": "Arial",
            "size": 36.0,
            "weight": 300,
            "color": "#a09890"
          },
          "transform": {
            "position": [540, 570],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 20, "v": 1.0 }
            ]
          }
        },
        {
          "id": "corner_accent_tl",
          "type": "shape",
          "in": 15,
          "out": 90,
          "shape": {
            "shape_type": "rect",
            "width": 60,
            "height": 2,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [80, 80],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 0.6 }
            ]
          }
        },
        {
          "id": "corner_accent_br",
          "type": "shape",
          "in": 15,
          "out": 90,
          "shape": {
            "shape_type": "rect",
            "width": 60,
            "height": 2,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [1000, 1000],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 0.6 }
            ]
          }
        }
      ]
    }
  }
}
