              { "t": 20, "v": [1.2, 1.2], "easing": "ease_in_out" },
              { "t": 40, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 70, "v": [0.7, 0.7], "easing": "ease_in" },
              { "t": 90, "v": [0.0, 0.0] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 8, "v": 0.9 },
              { "t": 75, "v": 0.9, "easing": "ease_in" },
              { "t": 90, "v": 0.0 }
            ]
          }
        },
        {
          "id": "sparkle_1",
          "type": "shape",
          "in": 5,
          "out": 80,
          "shape": { "shape_type": "ellipse", "width": 6, "height": 6, "fill": "#ffffff" },
          "blend_mode": "add",
          "effects": [{ "type": "glow", "color": "#fff86b", "radius": 6.0, "intensity": 1.0 }],
          "transform": {
            "position": [
              { "t": 5, "v": [1020, 480], "easing": "ease_in" },
              { "t": 80, "v": [1800, 80] }
            ],
            "opacity": [
              { "t": 5, "v": 0.0 }, { "t": 12, "v": 1.0 },
              { "t": 25, "v": 0.0 }, { "t": 35, "v": 1.0 },
              { "t": 50, "v": 0.0 }, { "t": 60, "v": 1.0 },
              { "t": 75, "v": 0.0 }
            ]
          }
        },
        {
          "id": "sparkle_2",
          "type": "shape",
          "in": 8,
          "out": 78,
          "shape": { "shape_type": "ellipse", "width": 5, "height": 5, "fill": "#ffffff" },
          "blend_mode": "add",
          "effects": [{ "type": "glow", "color": "#ffffff", "radius": 5.0, "intensity": 1.0 }],
          "transform": {
            "position": [
              { "t": 8, "v": [900, 600], "easing": "ease_in" },
              { "t": 78, "v": [1750, 100] }
            ],
            "opacity": [
              { "t": 8, "v": 0.0 }, { "t": 18, "v": 1.0 },
              { "t": 30, "v": 0.0 }, { "t": 42, "v": 1.0 },
              { "t": 55, "v": 0.0 }, { "t": 65, "v": 1.0 },
              { "t": 78, "v": 0.0 }
            ]
          }
        }
      ]
    }
  },
  "assets": { "fonts": [] }
}
