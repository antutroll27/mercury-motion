{
  "version": "1.0",
  "meta": {
    "name": "Golden Star",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 90,
    "root": "main",
    "background": "#0a0a14"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "bg_gradient",
          "type": "gradient",
          "in": 0,
          "out": 90,
          "fill": "parent",
          "gradient": {
            "gradient_type": "radial",
            "center": [0.5, 0.5],
            "radius": 0.7,
            "colors": [
              { "offset": 0.0, "color": "#1a1a3e" },
              { "offset": 0.5, "color": "#0f0f2a" },
              { "offset": 1.0, "color": "#0a0a14" }
            ]
          },
          "transform": { "position": [960, 540] }
        },
        {
          "id": "outer_glow",
          "type": "shape",
          "in": 0,
          "out": 90,
          "shape": {
            "shape_type": "ellipse",
            "width": 400,
            "height": 400,
            "fill": "#f5c33d"
          },
          "effects": [
            { "type": "gaussian_blur", "radius": 60.0 }
          ],
          "blend_mode": "add",
          "transform": {
            "position": [
              { "t": 0, "v": [960, 540], "easing": "ease_in" },
              { "t": 70, "v": [1700, 150], "easing": "ease_in" },
              { "t": 90, "v": [2100, -100] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 10, "v": 0.3, "easing": "ease_in_out" },
              { "t": 60, "v": 0.25, "easing": "ease_in" },
