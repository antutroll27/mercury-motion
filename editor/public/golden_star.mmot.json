              { "t": 15, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 70, "v": [0.6, 0.6], "easing": "ease_in" },
              { "t": 90, "v": [0.2, 0.2] }
            ]
          }
        },
        {
          "id": "star_outer",
          "type": "shape",
          "in": 0,
          "out": 90,
          "shape": {
            "shape_type": "polygon",
            "points": [
              [0, -140], [32, -45], [114, -45], [52, 8],
              [70, 95], [0, 45], [-70, 95], [-52, 8],
              [-114, -45], [-32, -45]
