          "transform": {
            "position": [
              { "t": 0, "v": [960, 540], "easing": "ease_in" },
              { "t": 70, "v": [1700, 150], "easing": "ease_in" },
              { "t": 90, "v": [2100, -100] }
            ],
            "rotation": [
              { "t": 0, "v": 0 },
              { "t": 90, "v": 720 }
            ],
            "scale": [
              { "t": 0, "v": [0.0, 0.0], "easing": { "type": "spring", "stiffness": 120, "damping": 14, "mass": 1.0 } },
              { "t": 20, "v": [1.2, 1.2], "easing": "ease_in_out" },
              { "t": 40, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 70, "v": [0.7, 0.7], "easing": "ease_in" },
              { "t": 90, "v": [0.0, 0.0] }
