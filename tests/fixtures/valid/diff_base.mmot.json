{
  "version": "1.0",
  "meta": {
    "name": "Diff Base",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 60,
    "root": "main",
    "background": "#003049"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "bg",
          "type": "solid",
          "in": 0,
          "out": 60,
          "color": "#1a1a2e",
          "fill": "parent",
          "transform": {
            "position": [960, 540]
          }
        },
        {
          "id": "title",
          "type": "text",
          "in": 0,
          "out": 60,
          "text": "Hello",
          "font": {
            "family": "Inter",
            "size": 48,
            "weight": 700,
            "color": "#f5f0e8"
          },
          "transform": {
            "position": [960, 540],
            "opacity": 1.0
          }
        }
      ]
    }
  },
  "assets": {
    "fonts": []
  }
}
