{
  "version": "1.0",
  "meta": {
    "name": "ButtonPulse",
    "width": 240,
    "height": 60,
    "fps": 30,
    "duration": 45,
    "background": "#0a0a14",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "button_glow",
          "type": "shape",
          "in": 0,
          "out": 45,
          "shape": {
            "shape_type": "rect",
            "width": 210,
            "height": 48,
            "corner_radius": 24,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [120, 30],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 11, "v": [1.08, 1.08], "easing": "ease_in_out" },
              { "t": 22, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 33, "v": [1.08, 1.08], "easing": "ease_in_out" },
              { "t": 45, "v": [1.0, 1.0] }
            ],
            "opacity": [
              { "t": 0, "v": 0.3, "easing": "ease_in_out" },
              { "t": 11, "v": 0.5, "easing": "ease_in_out" },
              { "t": 22, "v": 0.3, "easing": "ease_in_out" },
              { "t": 33, "v": 0.5, "easing": "ease_in_out" },
              { "t": 45, "v": 0.3 }
            ]
          },
          "effects": [
            { "type": "gaussian_blur", "radius": 15.0 }
          ]
        },
        {
          "id": "button_bg",
          "type": "shape",
          "in": 0,
          "out": 45,
          "shape": {
            "shape_type": "rect",
            "width": 200,
            "height": 44,
            "corner_radius": 22,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [120, 30],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 11, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 22, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 33, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 45, "v": [1.0, 1.0] }
            ]
          },
          "effects": [
            { "type": "drop_shadow", "color": "#8b0000", "offset_x": 0.0, "offset_y": 3.0, "blur": 8.0, "opacity": 0.4 }
          ]
        },
        {
          "id": "button_highlight",
          "type": "shape",
          "in": 0,
          "out": 45,
          "shape": {
            "shape_type": "rect",
            "width": 180,
            "height": 20,
            "corner_radius": 10,
            "fill": "#e8413f"
          },
          "transform": {
            "position": [120, 23],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 11, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 22, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 33, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 45, "v": [1.0, 1.0] }
            ],
            "opacity": 0.2
          }
        },
        {
          "id": "button_text",
          "type": "text",
          "in": 0,
          "out": 45,
          "text": "CLICK ME",
          "font": { "family": "Arial", "size": 18.0, "weight": 700, "color": "#ffffff" },
          "transform": {
            "position": [120, 30],
            "scale": [
              { "t": 0, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 11, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 22, "v": [1.0, 1.0], "easing": "ease_in_out" },
              { "t": 33, "v": [1.04, 1.04], "easing": "ease_in_out" },
              { "t": 45, "v": [1.0, 1.0] }
            ]
          }
        }
      ]
    }
  }
}
