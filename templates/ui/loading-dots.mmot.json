              { "t": 0, "v": [140, 30] },
              { "t": 6, "v": [140, 30], "easing": "ease_in_out" },
              { "t": 9, "v": [140, 20], "easing": "ease_in_out" },
              { "t": 12, "v": [140, 30], "easing": "ease_in_out" },
              { "t": 15, "v": [140, 30] }
            ],
            "opacity": [
              { "t": 0, "v": 0.4 },
              { "t": 6, "v": 0.4, "easing": "ease_in_out" },
              { "t": 9, "v": 1.0, "easing": "ease_in_out" },
              { "t": 12, "v": 0.4, "easing": "ease_in_out" },
              { "t": 15, "v": 0.4 }
