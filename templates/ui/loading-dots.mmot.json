{
  "version": "1.0",
  "meta": {
    "name": "LoadingDots",
    "width": 200,
    "height": 60,
    "fps": 15,
    "duration": 15,
    "background": "#0a0a14",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
