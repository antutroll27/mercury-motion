            "opacity": [
              { "t": 0, "v": 0.4 },
              { "t": 3, "v": 0.4, "easing": "ease_in_out" },
              { "t": 6, "v": 1.0, "easing": "ease_in_out" },
              { "t": 9, "v": 0.4, "easing": "ease_in_out" },
              { "t": 15, "v": 0.4 }
            ]
          }
        },
        {
          "id": "dot_3",
          "type": "shape",
          "in": 0,
          "out": 15,
          "shape": { "shape_type": "ellipse", "width": 16, "height": 16, "fill": "#f5f0e8" },
          "transform": {
