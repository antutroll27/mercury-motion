{
  "version": "1.0",
  "meta": {
    "name": "InstagramPost",
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "duration": 90,
    "background": "#0a0a1a",
    "root": "main"
  },
  "compositions": {
    "main": {
      "layers": [
        {
          "id": "bg_gradient",
          "type": "gradient",
          "in": 0,
          "out": 90,
          "gradient": {
            "gradient_type": "radial",
            "center": [0.5, 0.4],
            "radius": 1.0,
            "colors": [
              { "offset": 0.0, "color": "#1a1a3e" },
              { "offset": 0.7, "color": "#10102a" },
              { "offset": 1.0, "color": "#0a0a1a" }
            ]
          },
          "fill": "parent",
          "transform": { "position": [540, 540] }
        },
        {
          "id": "headline",
          "type": "text",
          "in": 5,
          "out": 90,
          "text": "YOUR HEADLINE",
          "font": {
            "family": "Arial",
            "size": 56.0,
            "weight": 700,
            "color": "#f5f0e8"
          },
          "transform": {
            "position": [
              { "t": 0, "v": [540, 560], "easing": "ease_out" },
              { "t": 18, "v": [540, 480] }
            ],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 12, "v": 1.0 }
            ]
          }
        },
        {
          "id": "separator_line",
          "type": "shape",
          "in": 15,
          "out": 90,
          "shape": {
            "shape_type": "rect",
            "width": 200,
            "height": 2,
            "fill": "#c1121f"
          },
          "transform": {
            "position": [540, 530],
            "scale": [
              { "t": 0, "v": [0.0, 1.0], "easing": { "type": "cubic_bezier", "x1": 0.16, "y1": 1.0, "x2": 0.3, "y2": 1.0 } },
              { "t": 18, "v": [1.0, 1.0] }
            ],
            "opacity": 1.0
          }
        },
        {
          "id": "subtitle",
          "type": "text",
          "in": 20,
          "out": 90,
          "text": "Add your message here",
          "font": {
            "family": "Arial",
            "size": 24.0,
            "weight": 400,
            "color": "#a09890"
          },
          "transform": {
            "position": [540, 575],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 1.0 }
            ]
          }
        },
        {
          "id": "bottom_bar",
          "type": "shape",
          "in": 0,
          "out": 90,
          "shape": {
            "shape_type": "rect",
            "width": 1080,
            "height": 60,
            "fill": "#0f0f1f"
          },
          "transform": {
            "position": [540, 1050],
            "opacity": 0.8
          }
        },
        {
          "id": "handle_text",
          "type": "text",
          "in": 30,
          "out": 90,
          "text": "@yourhandle",
          "font": {
            "family": "Arial",
            "size": 20.0,
            "weight": 400,
            "color": "#808090"
          },
          "transform": {
            "position": [540, 1050],
            "opacity": [
              { "t": 0, "v": 0.0, "easing": "ease_out" },
              { "t": 15, "v": 1.0 }
            ]
          }
        }
      ]
    }
  }
}
